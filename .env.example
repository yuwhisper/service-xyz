# Server
PORT=3000
NODE_ENV=development

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=zyx
DB_USER=your_db_user
DB_PASS=your_db_password

# JWT
JWT_SECRET=change-me-to-a-random-string
JWT_EXPIRES_IN=7d

# Admin account (created on first install)
ADMIN_EMAIL=admin@service-xyz.com
ADMIN_PASSWORD=admin123

# Register
CLOSE_REGISTER=false

# Ozon FBO shipment (POST /service/zyx/ozon/fahuo)
OZON_ARCHIVE_ROOT=/opt/service-zyx/ozon-fahuo-data
# Optional overrides; defaults fall back to DB_* above
# OZON_DB_HOST=127.0.0.1
# OZON_DB_PORT=3306
# OZON_DB_NAME=zyx
# OZON_DB_USER=your_db_user
# OZON_DB_PASS=your_db_password
# JSON map of shop -> {client_id, api_key}
# OZON_SHOP_DATA={"OZ-005-RU":{"client_id":"...","api_key":"..."}}
# OZON_CROSSDOCK_DROP_OFF=МО_ЩЕРБИНКА_ХАБ

# DingTalk dingpan (POST /service/zyx/dingtalk/dingpan/upload)
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_UNION_ID=
DINGTALK_DEFAULT_FOLDER_URL=https://qr.dingtalk.com/page/yunpan?route=previewDentry&spaceId=27567080023&fileId=226699540842&type=folder
DINGTALK_UPLOAD_ALLOW_ROOTS=/opt/service-zyx/ozon-fahuo-data
OZON_UPLOAD_DINGPAN=true

# Jushuitan SKU query (询价表图片/运营成本价)
JUSHUITAN_APP_KEY=
JUSHUITAN_APP_SECRET=
# 首次授权码或 getInitToken 用 code；也可直接配置 ACCESS_TOKEN
JUSHUITAN_AUTH_CODE=
JUSHUITAN_ACCESS_TOKEN=
JUSHUITAN_REFRESH_TOKEN=
